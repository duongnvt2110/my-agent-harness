{
  "schema_version": 1,
  "canonicalization_version": 1,
  "artifact": "v3-run-state",
  "required": [
    "schema_version",
    "canonicalization_version",
    "run_id",
    "task_id",
    "state",
    "active_function",
    "updated_at"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "canonicalization_version": {"type": "integer", "const": 1},
    "run_id": {"type": "string", "min_length": 1},
    "task_id": {"type": "string", "min_length": 1},
    "state": {"type": "string", "min_length": 1},
    "active_function": {"type": "string", "min_length": 1},
    "updated_at": {"type": "string", "min_length": 1},
    "previous_state": {"type": ["string", "null"]},
    "event_sequence": {"type": "integer", "minimum": 0},
    "event_hash": {"type": "string", "min_length": 64}
  },
  "additional_properties": false
}
